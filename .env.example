# ============================================================
# Dashboard PIP Puslapdik — contoh konfigurasi environment
# Salin menjadi `.env.local` (frontend) lalu isi nilainya.
# JANGAN meng-commit file .env berisi nilai asli.
# ============================================================

# ------------------------------------------------------------
# FRONTEND (Vite — prefiks VITE_ terekspos ke browser;
# padanan NEXT_PUBLIC_* pada Docs/09 = VITE_* di project ini)
# ------------------------------------------------------------

# Mode sumber data:
#   local    = tanpa backend; data contoh tersimpan di perangkat
#   supabase = backend produksi (wajib kredensial Supabase di bawah)
VITE_DATA_MODE=local

# URL project Supabase, contoh: https://srdqjvftjdklqebgvlco.supabase.co
VITE_SUPABASE_URL=
# Anon/public key project Supabase (BUKAN service_role!)
VITE_SUPABASE_ANON_KEY=

# Domain email akun aplikasi (login username → email pada domain ini).
# Default pip.local → username `tim-pip` = tim-pip@pip.local
VITE_AUTH_EMAIL_DOMAIN=pip.local

# Kredensial khusus E2E mode Supabase (opsional di local, wajib untuk test
# terhadap Supabase Auth nyata). Isi hanya di `.env.local` / secret CI.
PIP_E2E_USER_USERNAME=user
PIP_E2E_USER_PASSWORD=
PIP_E2E_ADMIN_USERNAME=admin
PIP_E2E_ADMIN_PASSWORD=

# ------------------------------------------------------------
# SERVER (Vercel Functions — TIDAK PERNAH terekspos ke browser.
# Isi di Vercel Project Settings → Environment Variables.)
# ------------------------------------------------------------

# Supabase (server): URL sama dengan VITE_SUPABASE_URL
SUPABASE_URL=
# Service role key — HANYA server; jangan ditaruh pada variabel VITE_*
SUPABASE_SERVICE_ROLE_KEY=

# Mode akses Google Sheets:
#   service_account = koneksi sistem (UTAMA) — tanpa login Google
#   oauth           = alternatif (satu akun Admin menghubungkan Google)
GOOGLE_SHEETS_ACCESS_MODE=service_account

# Service Account (mode utama, read-only). Bagikan kedua spreadsheet ke email
# ini dengan akses Viewer. Private key RAHASIA — hanya server; jangan commit.
# Newline pada private key ditulis sebagai "\n" (satu baris) — kode menormalkan.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google OAuth (mode alternatif — satu akun Admin membaca Google Sheets read-only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback: lokal  = http://localhost:3000/api/integrations/google/callback
#           produksi = https://<domain-anda>/api/integrations/google/callback
GOOGLE_REDIRECT_URI=
# Kunci enkripsi token (string acak ≥32 karakter; jangan pernah diganti
# setelah ada token tersimpan — token lama tidak akan terbaca)
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Secret webhook Apps Script (samakan dengan Code.gs)
GOOGLE_WEBHOOK_SECRET=

# URL aplikasi (dipakai redirect setelah OAuth), contoh:
# https://pip-dashboard.vercel.app
NEXT_PUBLIC_APP_URL=

# Opsional: secret khusus cron rekonsiliasi (default memakai GOOGLE_WEBHOOK_SECRET)
CRON_SECRET=
