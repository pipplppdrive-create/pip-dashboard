# ============================================================
# Dashboard PIP Puslapdik — contoh konfigurasi environment
# Salin file ini menjadi `.env.local` lalu isi nilainya.
# JANGAN meng-commit file .env yang berisi nilai asli.
# ============================================================

# Mode sumber data:
#   local    = tanpa backend; data tersimpan di perangkat (untuk development/demo)
#   supabase = backend produksi (wajib mengisi kredensial Supabase di bawah)
VITE_DATA_MODE=local

# --- Supabase (hanya jika VITE_DATA_MODE=supabase) ---
# URL project Supabase, contoh: https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=
# Anon/public key project Supabase (bukan service_role key!)
VITE_SUPABASE_ANON_KEY=
