# ============================================================
# Dashboard PIP Puslapdik — contoh konfigurasi environment
# Salin file ini menjadi `.env.local` lalu isi nilainya.
# JANGAN meng-commit file .env yang berisi nilai asli.
# ============================================================

# Mode sumber data:
#   local    = tanpa backend; data tersimpan di perangkat (development/demo)
#   supabase = backend produksi (wajib mengisi kredensial Supabase di bawah)
VITE_DATA_MODE=local

# --- Supabase (hanya jika VITE_DATA_MODE=supabase) ---
# URL project Supabase, contoh: https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=
# Anon/public key project Supabase (bukan service_role key!)
VITE_SUPABASE_ANON_KEY=

# Domain email akun aplikasi (akun dibuat di Supabase Auth dengan domain ini).
# Default: pip.local → akun tim = tim@pip.local, admin = admin@pip.local
VITE_AUTH_EMAIL_DOMAIN=pip.local
# Override penuh email akun bersama Tim PIP (opsional)
VITE_AUTH_USER_EMAIL=

# CATATAN: SUPABASE_SERVICE_ROLE_KEY hanya dipakai edge function di server
# (supabase functions), TIDAK PERNAH ditaruh pada env aplikasi frontend ini.
